<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notatnik (wariant bazowy)</title>
    <style>
        body { font-family: sans-serif; max-width: 820px; margin: 1rem auto; padding: 0 1rem; }
        nav a { margin-right: 12px; } .err { color: #b00; } .muted { color: #777; font-size: .9em; }
        input, textarea { display:block; margin:.3rem 0; width:100%; } form { margin:.6rem 0; }
    </style>
</head>
<body>
    <nav>
        <a href="/notes">Notatki</a>
        <a href="/notes/new">Nowa</a>
        <a href="/profile">Profil</a>
        <a href="/admin">Admin</a>
        <form method="post" action="/logout" style="display:inline">
            @Html.AntiForgeryToken()
            <button type="submit">Wyloguj</button>
        </form>
        <a href="/login">Zaloguj</a>
    </nav>
    <hr />
    @RenderBody()
</body>
</html>
